{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "run-0",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": [
                "--q", "topics-train_cs.xml",
                "--d", "documents_cs.lst",
                "--r", "run-0_cs",
                "--o", "run-0_train_cs.res",
                "-p", "task1/A1/"
                
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "run-0-en",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": [
                "--q", "topics-train_en.xml",
                "--d", "documents_en.lst",
                "--r", "run-0_en",
                "--o", "run-0_train_en.res",
                "-p", "task1/A1/",
                "-l", "en"
            ],
            "console": "integratedTerminal"
        },
    ]
}